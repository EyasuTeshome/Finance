# ─── Auth ────────────────────────────────────────────────────────────────────
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_random_64_char_hex_string

# Bcrypt-hashed password for the single admin user.
# Generate: node -e "const b=require('bcryptjs');console.log(b.hashSync('yourpassword',12))"
ADMIN_PASSWORD_HASH=$2b$12$...

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# From your Neon project dashboard → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ─── CORS / Frontend ─────────────────────────────────────────────────────────
# Your Vercel frontend URL (comma-separated if multiple, e.g. preview + production)
CORS_ORIGIN=https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# ─── Frontend env (set in Vercel dashboard, not here) ────────────────────────
# VITE_API_URL=https://your-app.onrender.com/api
